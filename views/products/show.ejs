<% layout('layouts/boilerplate') %>

<div class="row align-items-stretch">
    <a class="text-secondary mb-5" href="/products" style="text-decoration: none;">← Back to Products</a>
    <div class="col-lg-6 align-items-center">
        <img src="<%= product.image %>" class="img-fluid rounded" alt="<%= product.name %>">
    </div>
    <div class="col-lg-6 d-flex flex-column justify-content-between">
        <div>
            <h1><%= product.name  %></h1>
            <div class="mb-4"><a href="/products?category=<%= product.category %>" style="text-decoration: none;color:hotpink; background-color: pink; border-radius: 30%;" ><%= product.category %></a></div>
            <h6 class="card-text">₹<%= product.price %> <small class="text-body-secondary"> /unit</small></h6>
        </div>
        
        <p>Fresh, high-quality <%= product.name.toLowerCase() %> sourced with care. Perfect for everyday cooking, healthy meals, and bringing natural goodness to your table.</p>

        <div class="d-flex gap-4">
            <a class="btn btn-success btn-lg flex-fill" href="/products/<%= product._id%>/edit">Edit</a>
         <form class="flex-fill" action="/products/<%= product._id %>?_method=DELETE" method="POST">
            <button class="btn btn-danger btn-lg w-100">Delete</button>
        </form>
        </div>
    </div>
</div>