<% layout('layouts/boilerplate') %>
<div class="row align-items-center">
<a class="text-secondary mb-4" href="/products" style="text-decoration: none;">← Back to Products</a>
<div class="col-lg-6">
    
    <h1 class="text">🍃 Add a Product</h1>
    <p class="text-secondary">Fill in the details to add a new Product to your store.</p>
    
    <form action="/products" method="POST" novalidate class="validated-form">
      <div class="mb-3">
        <label class="form-label" for="name">Product name:</label>
        <input
          class="form-control"
          type="text"
          id="name"
          name="name"
          placeholder="e.g. Organic Apple"
          required
        />
        <div class="valid-feedback">
          looks good!
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label" for="price">Price (in ₹ per unit):</label>
        <div class="input-group">
          <span class="input-group-text" id="price-label">₹</span>
          <input
            type="number"
            class="form-control"
            id="price"
            name="price"
            aria-label="price"
            aria-describedby="price-label"
            placeholder="e.g. 120"
            required
          />
          <div class="valid-feedback">
          looks good!
        </div>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label" for="image">Image Url:</label>
        <input
          class="form-control"
          type="url"
          id="image"
          name="image"
          required
        />
        <div class="valid-feedback">
          looks good!
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label" for="category">Select Category: </label>
        <select class="form-select" type="text" name="category" id="category">
            <% for(let category of categories){ %>
                <option value="<%= category %>"><%= category %></option>
                <% } %>
        </select>
        <div class="valid-feedback">
          looks good!
        </div>
        </div>
        
        <div class="d-grid mb-3">
            <button class="btn btn-success">Add Product</button>
        </div>
    </form>
  
</div>

<div class="col-lg-6 align-items-center">
    <img src="/images/crate.png" 
    class="img-fluid rounded"
    alt="Fresh Fruits and Vegetables">
</div>

</div>
